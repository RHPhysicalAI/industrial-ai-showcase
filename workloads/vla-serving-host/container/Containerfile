# This project was developed with assistance from AI tools.
# Phase 1 host-native VLA server. Two build modes:
#
# MOCK (default; fast; no GPU; no model download): ~300 MB image.
#   podman build -f workloads/vla-serving-host/container/Containerfile \
#     -t localhost/openvla-server:dev .
#
# REAL (with CUDA + PyTorch, for running actual OpenVLA-7B on NVIDIA GPUs):
#   podman build -f workloads/vla-serving-host/container/Containerfile \
#     --build-arg=BASE_FLAVOR=cuda \
#     -t localhost/openvla-server:cuda .
#
# Swap the Quadlet Image= to the tag you want. Use :dev for wiring verification,
# :cuda once you're ready for real inference.
ARG BASE_FLAVOR=slim

FROM registry.access.redhat.com/ubi9/python-312:latest AS slim

FROM nvcr.io/nvidia/pytorch:24.12-py3 AS cuda
# NVIDIA PyTorch 2.6 + CUDA 12.6 + Python 3.12 pre-installed.
# Optimized for NVIDIA GPUs (L40S, L4).
ENV PIP_BREAK_SYSTEM_PACKAGES=1
ENV PIP_ROOT_USER_ACTION=ignore

FROM ${BASE_FLAVOR} AS final

USER 0

ENV PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/app

COPY workloads/vla-serving-host/pyproject.toml /opt/app/vla-serving-host/
COPY workloads/vla-serving-host/src /opt/app/vla-serving-host/src

# Install service-level deps. In :slim we install everything except torch/torchvision
# (the service defaults to VLA_MODE=mock which never imports torch). In :rocm the
# base already has torch; we install --no-deps to avoid overwriting it.
RUN pip3 install --no-cache-dir \
        fastapi "uvicorn[standard]" \
        pydantic pydantic-settings \
        structlog pillow numpy \
    && pip3 install --no-cache-dir --no-deps /opt/app/vla-serving-host \
    && chown -R 1001:0 /opt/app

# Real-model deps only land in the :cuda image.
# transformers pinned to 4.40.x — OpenVLA's trust_remote_code registrations
# target the pre-5.0 API (AutoModelForVision2Seq, LlamaTokenizer behaviors).
# accelerate + timm versions pinned compatibly with transformers 4.40.
RUN if [ -f /etc/os-release ] && grep -q ubuntu /etc/os-release; then \
        pip3 install --no-cache-dir \
            "transformers==4.40.1" \
            "tokenizers>=0.19,<0.20" \
            "accelerate==0.30.1" \
            "timm==0.9.16" \
            sentencepiece ; \
    fi

USER 1001

EXPOSE 8000

CMD ["uvicorn", "openvla_server.main:app", "--host", "0.0.0.0", "--port", "8000"]
